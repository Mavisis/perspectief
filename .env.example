# ── Supabase ─────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...          # safe for Edge Functions (RLS enforced)
SUPABASE_SERVICE_KEY=eyJ...       # server-only — used by pipeline for writes

# ── Google AI (pipeline) ─────────────────────────────────────
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSy...

# ── Pipeline security ─────────────────────────────────────────
# Authenticates cron calls to /api/pipeline/ingest
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
PIPELINE_SECRET=your-64-char-hex-here
