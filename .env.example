# ── Supabase ─────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...          # safe to expose to Edge Functions (RLS enforced)
SUPABASE_SERVICE_KEY=eyJ...       # server-only, never expose to frontend

# ── Claude API (pipeline) ─────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Pipeline security ─────────────────────────────────────────
# Random secret used to authenticate cron calls to /api/pipeline/ingest
# Generate: openssl rand -hex 32
PIPELINE_SECRET=your-secret-here
